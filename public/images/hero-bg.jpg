<svg width="1920" height="1080" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="sky" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#fdf4ff"/>
      <stop offset="40%" style="stop-color:#fce7f3"/>
      <stop offset="70%" style="stop-color:#fbcfe8"/>
      <stop offset="100%" style="stop-color:#f9a8d4"/>
    </linearGradient>
    <linearGradient id="mtn1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:0.4"/>
      <stop offset="100%" style="stop-color:#5b21b6;stop-opacity:0.2"/>
    </linearGradient>
    <linearGradient id="mtn2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#a855f7;stop-opacity:0.35"/>
      <stop offset="100%" style="stop-color:#9333ea;stop-opacity:0.15"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#sky)"/>
  <!-- Mountains -->
  <polygon points="0,1080 400,400 800,1080" fill="url(#mtn1)"/>
  <polygon points="600,1080 1100,350 1600,1080" fill="url(#mtn2)"/>
  <polygon points="1200,1080 1600,450 2000,1080" fill="url(#mtn1)"/>
  <!-- Sun/Moon -->
  <circle cx="960" cy="450" r="100" fill="#fbbf24" opacity="0.5"/>
  <circle cx="960" cy="450" r="70" fill="#fcd34d" opacity="0.6"/>
  <!-- River -->
  <path d="M 0 850 Q 480 750 960 800 Q 1440 850 1920 750" stroke="#60a5fa" stroke-width="4" fill="none" opacity="0.4"/>
  <path d="M 0 880 Q 640 780 960 820 Q 1280 860 1920 740" stroke="#93c5fd" stroke-width="2" fill="none" opacity="0.3"/>
  <!-- Clouds -->
  <ellipse cx="200" cy="150" rx="120" ry="40" fill="#f3e8ff" opacity="0.4"/>
  <ellipse cx="1700" cy="200" rx="150" ry="50" fill="#fae8ff" opacity="0.35"/>
  <text x="960" y="1020" font-family="Georgia, serif" font-size="80" fill="#7c3aed" text-anchor="middle" opacity="0.2" font-weight="bold">Rishikesh</text>
</svg>
