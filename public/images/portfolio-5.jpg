<svg width="600" height="800" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg5" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e1b4b"/>
      <stop offset="50%" style="stop-color:#312e81"/>
      <stop offset="100%" style="stop-color:#3730a3"/>
    </linearGradient>
    <radialGradient id="moon" cx="50%" cy="30%" r="30%">
      <stop offset="0%" style="stop-color:#fef3c7;stop-opacity:0.9"/>
      <stop offset="100%" style="stop-color:#fef3c7;stop-opacity:0"/>
    </radialGradient>
  </defs>
  <rect width="600" height="800" fill="url(#bg5)"/>
  <circle cx="300" cy="200" r="80" fill="url(#moon)"/>
  <circle cx="150" cy="150" r="3" fill="#fbbf24" opacity="0.6"/>
  <circle cx="450" cy="180" r="2" fill="#fcd34d" opacity="0.7"/>
  <circle cx="200" cy="300" r="2.5" fill="#fde047" opacity="0.5"/>
