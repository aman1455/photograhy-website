  <path d="M 150 600 Q 300 500 450 600" stroke="#818cf8" stroke-width="2" fill="none" opacity="0.3"/>
  <text x="300" y="760" font-family="Georgia, serif" font-size="32" fill="#c7d2fe" text-anchor="middle" opacity="0.7" font-weight="bold">Night Romance</text>
</svg>
